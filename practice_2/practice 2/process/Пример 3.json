чных данных\",window_log=True, current_language=\"ru\")\n            )\n            log_process(block_text='Присвоить значение переменной')\n            # Присваивает переменной значение вставки\n            log_process(window_log=True,block_text='Присвоить значение переменной')\n            #xBocb=(ET[TL?-cLOo{[\n            full_name = interaction_with_excel_data.get_excel_cell_data(data=table,column='B',index=new,block_text=\"Получить значение ячейки табличных данных\",window_log=True, current_language=\"ru\")\n            log_process(block_text='Присвоить значение переменной')\n            # Присваивает переменной значение вставки\n            log_process(window_log=True,block_text='Присвоить значение переменной')\n            #3M~ZaITUMB+U3:)oVrtD\n            sum2 = interaction_with_excel_data.get_excel_cell_data(data=table,column='D',index=new,block_text=\"Получить значение ячейки табличных данных\",window_log=True, current_language=\"ru\")\n            log_process(block_text='Присвоить значение переменной')\n            \n\n            log_process(block_text='Группировка блоков')\n\n            # Присваивает переменной значение вставки\n            log_process(window_log=True,block_text='Присвоить значение переменной')\n            #9M|]NK!4xObiy:BRDHM;\n            year = find_part_str.find_part_str_2(date,'','.','FALSE','FALSE',block_text=\"Получить часть текста\",window_log=True, current_language=\"ru\")\n\n            log_process(block_text='Присвоить значение переменной')\n\n            log_process(window_log=True,block_text='Если – выполнить')\n            #fRueX7$b?`TDe^%SEz#n\n            if year == '25':\n                #l_+)ja+U~U`K_YL4r~ET\n                user_notice_2.user_notice('Индексацию не проводим!',None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n            else:\n                # Присваивает переменной значение вставки\n                log_process(window_log=True,block_text='Присвоить значение переменной')\n                #Wp/]As*%WzkV7fzlrF{X\n                index = sum2 * 1.1\n\n                log_process(block_text='Присвоить значение переменной')\n\n                #$?FP5/B/J(uDiMm6Z^[0\n                user_notice_2.user_notice(index,None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n\n            log_process(block_text='Если – выполнить')\n\n\n            logger.info(f'Завершение работы робота: {puzzle_logger_path}')\n            send_message_websocket(message_type=\"python_end\")\n        except Exception as error_puzzle:\n            logger.error(f'{puzzle_logger_path} ' + f'Ошибка: {error_puzzle}')\n            error_puzzle_format=format_traceback(error_puzzle)\n            send_message_websocket(message_type=\"python_error\", message=error_puzzle_format)\n            raise Exception(error_puzzle)\n    main_sentry_862_proc()","pId":"sentry_862"}
